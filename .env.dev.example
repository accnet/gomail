# GoMail local host configuration for ./start.sh

APP_ENV=development
APP_NAME=GoMail
APP_BASE_URL=http://localhost:8080
API_BASE_URL=http://localhost:8080/api
SAAS_DOMAIN=localhost

HTTP_HOST=0.0.0.0
HTTP_PORT=8080
TRUSTED_PROXIES=172.16.0.0/12,10.0.0.0/8,192.168.0.0/16

SMTP_HOST=0.0.0.0
SMTP_PORT=2525
SMTP_HOSTNAME=mx.localhost
MX_TARGET=mx.localhost
MAX_MESSAGE_SIZE_MB=25

POSTGRES_DB=gomail
POSTGRES_USER=gomail
POSTGRES_PASSWORD=gomail_password
DATABASE_URL=postgres://gomail:gomail_password@127.0.0.1:5432/gomail?sslmode=disable

REDIS_ADDR=127.0.0.1:6379
REDIS_PASSWORD=
REDIS_DB=0

JWT_SECRET=dev-secret-change-me-local-compose
ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_TOKEN_TTL_DAYS=30

DEFAULT_ADMIN_EMAIL=admin@example.com
DEFAULT_ADMIN_PASSWORD=change-me-before-deploy
DEFAULT_ADMIN_NAME="Super Admin"
DEFAULT_ADMIN_MAX_DOMAINS=100
DEFAULT_ADMIN_MAX_INBOXES=1000
DEFAULT_ADMIN_MAX_MESSAGE_SIZE_MB=25
DEFAULT_ADMIN_MAX_ATTACHMENT_SIZE_MB=25
DEFAULT_ADMIN_MAX_STORAGE_GB=100
DEFAULT_ADMIN_MAX_WEBSITES=100

STORAGE_ROOT=./data
ATTACHMENT_STORAGE_ROOT=./data/attachments
RAW_EMAIL_STORAGE_ROOT=./data/raw-eml
STATIC_SITES_ROOT=./data/static-sites
STATIC_SITES_MAX_ARCHIVE_BYTES=52428800
STATIC_SITES_MAX_EXTRACTED_BYTES=209715200
STATIC_SITES_MAX_FILE_COUNT=5000
STATIC_SITES_BASE_DOMAIN=localhost
STATIC_SERVER_ADDR=:8090

TRAEFIK_DYNAMIC_CONF_DIR=./data/traefik-dynamic
TRAEFIK_PUBLIC_IP=127.0.0.1

DOMAIN_VERIFY_TIMEOUT_SECONDS=10
DOMAIN_RECHECK_INTERVAL_MINUTES=30

CLAMAV_ENABLED=false
CLAMAV_ADDR=clamav:3310
BLOCK_FLAGGED_ATTACHMENTS=true
ALLOW_ADMIN_ATTACHMENT_OVERRIDE=true
SEED_DEMO_DATA=true

SMTP_AUTH_ENABLED=false
SMTP_AUTH_HOSTNAME=smtp.localhost
SMTP_AUTH_PORT=587
SMTP_AUTH_TLS_PORT=465
SMTP_RELAY_HOSTNAME=smtp.localhost
SMTP_RELAY_PUBLIC_IP=127.0.0.1
DKIM_ENABLED=false
DKIM_SELECTOR=gomail
DKIM_KEY_ENCRYPTION_SECRET=dev-dkim-key-encryption-secret-32
OUTBOUND_MODE=direct
OUTBOUND_RELAY_HOST=
OUTBOUND_RELAY_PORT=587
OUTBOUND_RELAY_USER=
OUTBOUND_RELAY_PASS=
MAX_DAILY_SEND_PER_KEY=0
