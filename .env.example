# GoMail deployment configuration

# Runtime
APP_ENV=production
APP_NAME=GoMail
APP_BASE_URL=https://mail.example.com
API_BASE_URL=https://mail.example.com/api
SAAS_DOMAIN=example.com

# HTTP API
HTTP_HOST=0.0.0.0
HTTP_PORT=8089
TRUSTED_PROXIES=

# Inbound SMTP
SMTP_HOST=0.0.0.0
SMTP_PORT=25
SMTP_HOSTNAME=mx.example.com
MX_TARGET=mx.example.com
MAX_MESSAGE_SIZE_MB=25

# Database
DATABASE_URL=postgres://gomail:gomail_password@postgres:5432/gomail?sslmode=disable

# Redis
REDIS_ADDR=redis:6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT and sessions
JWT_SECRET=change-me-use-a-long-random-secret
ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_TOKEN_TTL_DAYS=30

# Default super admin seeded on first deploy
DEFAULT_ADMIN_EMAIL=admin@example.com
DEFAULT_ADMIN_PASSWORD=change-me-before-deploy
DEFAULT_ADMIN_NAME=Super Admin
DEFAULT_ADMIN_MAX_DOMAINS=100
DEFAULT_ADMIN_MAX_INBOXES=1000
DEFAULT_ADMIN_MAX_MESSAGE_SIZE_MB=25
DEFAULT_ADMIN_MAX_ATTACHMENT_SIZE_MB=25
DEFAULT_ADMIN_MAX_STORAGE_GB=100

# Storage
STORAGE_ROOT=./data
ATTACHMENT_STORAGE_ROOT=./data/attachments
RAW_EMAIL_STORAGE_ROOT=./data/raw-eml

# Domain verification
DOMAIN_VERIFY_TIMEOUT_SECONDS=10
DOMAIN_RECHECK_INTERVAL_MINUTES=30

# Attachment scanning
CLAMAV_ENABLED=false
CLAMAV_ADDR=clamav:3310
BLOCK_FLAGGED_ATTACHMENTS=true
ALLOW_ADMIN_ATTACHMENT_OVERRIDE=true
